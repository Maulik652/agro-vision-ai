# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/agrovisionAI

# JWT / Auth
JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=agrovision-api
JWT_AUDIENCE=agrovision-client
AUTH_COOKIE_NAME=av_access_token

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin seed (optional)
ADMIN_EMAIL=admin@agrovision.com
ADMIN_PASSWORD=change_me

# Python integration (optional)
PYTHON_EXECUTABLE=python
CROP_SCAN_API_URL=http://127.0.0.1:8001/scan

# Weather provider + AI microservice
WEATHER_PROVIDER=openweather
OPENWEATHER_API_KEY=replace_with_openweather_api_key
WEATHER_AI_API_URL=http://127.0.0.1:8002/analyze

# Weather performance tuning
WEATHER_CACHE_TTL_MS=600000
WEATHER_SAVE_INTERVAL_MS=7200000
